@model InventoryManagementSystem.Web.Models.StockLevelsReportViewModel

@{
    ViewData["Title"] = "Current Stock Levels Report";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2><i class="bi bi-clipboard-data"></i> Current Stock Levels Report</h2>
            <p class="text-muted mb-0">Complete inventory overview as of @DateTime.Now.ToString("MMMM dd, yyyy HH:mm")</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Dashboard
            </a>
            <a asp-action="ExportStockLevels" class="btn btn-success">
                <i class="bi bi-download"></i> Export to CSV
            </a>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-2">Total Products</h6>
                    <h2 class="text-primary mb-0">@Model.Products.Count()</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-info">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-2">Total Items in Stock</h6>
                    <h2 class="text-info mb-0">@Model.TotalItems.ToString("N0")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <h6 class="text-muted mb-2">Total Inventory Value</h6>
                    <h2 class="text-success mb-0">@Model.TotalValue.ToString("C")</h2>
                </div>
            </div>
        </div>
    </div>

    @if (Model.LowStockCount > 0)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i>
            <strong>Attention:</strong> @Model.LowStockCount product(s) are currently at or below low stock threshold.
            <a asp-action="LowStockReport" class="alert-link">View Low Stock Report</a>
        </div>
    }

    <!-- Stock Levels Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">All Products</h5>
        </div>
        <div class="card-body">
            @if (!Model.Products.Any())
            {
                <p class="text-muted mb-0">No products found in inventory.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="stockTable">
                        <thead>
                            <tr>
                                <th>Product Name</th>
                                <th>SKU</th>
                                <th>Category</th>
                                <th>Supplier</th>
                                <th class="text-end">Unit Price</th>
                                <th class="text-center">Current Stock</th>
                                <th class="text-center">Threshold</th>
                                <th class="text-end">Inventory Value</th>
                                <th class="text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model.Products)
                            {
                                <tr class="@(product.IsLowStock ? "table-warning" : "")">
                                    <td>
                                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.ProductId">
                                            @product.Name
                                        </a>
                                    </td>
                                    <td><code>@product.SKU</code></td>
                                    <td>@product.Category</td>
                                    <td>@(product.SupplierName ?? "-")</td>
                                    <td class="text-end">@product.UnitPrice.ToString("C")</td>
                                    <td class="text-center">
                                        <span class="badge @(product.IsLowStock ? "bg-warning text-dark" : "bg-success")">
                                            @product.CurrentStock
                                        </span>
                                    </td>
                                    <td class="text-center">@product.LowStockThreshold</td>
                                    <td class="text-end">
                                        <strong>@product.InventoryValue.ToString("C")</strong>
                                    </td>
                                    <td class="text-center">
                                        @if (product.IsLowStock)
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-exclamation-triangle"></i> Low Stock
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle"></i> Normal
                                            </span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light fw-bold">
                                <td colspan="5" class="text-end">TOTALS:</td>
                                <td class="text-center">@Model.TotalItems.ToString("N0")</td>
                                <td></td>
                                <td class="text-end">@Model.TotalValue.ToString("C")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <p class="text-muted">
            <i class="bi bi-info-circle"></i>
            Report generated on @DateTime.Now.ToString("f")
        </p>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Simple table search functionality
            $('#searchInput').on('keyup', function() {
                var value = $(this).val().toLowerCase();
                $('#stockTable tbody tr').filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}