@model InventoryManagementSystem.Web.Models.SupplierViewModel

@{
	ViewData["Title"] = "Delete Supplier";

}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-8 offset-md-2">
			<h2 class="text-danger">Delete Supplier</h2>
			<hr />

			@if(!ViewBag.CanDelete)
			{
				<div class="alert alert-warning">
					<i class="bg-info bi-exclamation-triangle"></i>
					@ViewBag.DeleteWarning
				</div>
			}
			else
			{
				<div class="alert alert-danger">
					<i class="bi bi-exclamation-triangle"></i>
					Are you sure you want to delete this supplier? This action cannot be undone.
				</div>
			}

			<div class="card">
				<div class="card-body">
					<dl class="row">
						<dt class="col-sm-4">@Html.DisplayNameFor(model => model.Name)</dt>
						<dd class="col-sm-8">@Model.Name</dd>

						<dt class="col-sm-4">@Html.DisplayNameFor(model => model.ContactPerson)</dt>
						<dd class="col-sm-8">@Model.ContactPerson</dd>

						<dt class="col-sm-4">@Html.DisplayNameFor(model => model.Email)</dt>
						<dd class="col-sm-8">@Model.Email</dd>

						<dt class="col-sm-4">@Html.DisplayNameFor(model => model.Phone)</dt>
						<dd class="col-sm-8">@Model.Phone</dd>

						<dt class="col-sm-4">@Html.DisplayNameFor(model => model.ProductCount)</dt>
						<dd class="col-sm-8"><span class="badge bg-info">@Model.ProductCount products(s)</span></dd>
					</dl>
				</div>
			</div>

			<div class="mt-3">
				@if (ViewBag.CanDelete)
				{
					<form asp-action="Delete" method="post" class="d-inline">
						<input type="hidden" asp-for="SupplierId" />
						<button type="submit" class="btn btn-danger">
							<i class="bi bi-trash"></i> Confirm Delete
						</button>
					</form>
				}
				<a asp-action="Index" class="btn btn-secondary">Cancel</a>
			</div>
		</div>
	</div>
</div>
