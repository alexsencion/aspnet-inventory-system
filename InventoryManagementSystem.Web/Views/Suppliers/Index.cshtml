@model IEnumerable<InventoryManagementSystem.Web.Models.SupplierViewModel>

@{
    ViewData["Title"] = "Suppliers";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Suppliers</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Supplier
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Index" method="get" class="mb-3">
        <div class="row">
            <div class="col-md-6">
                <div class="input-group">
                    <input type="text" name="searchTerm" class="form-control"
                           placeholder="Search by name, contact person, or email..."
                           value="@ViewBag.SearchTerm">
                    <button class="btn btn-outline-secondary" type="submit">
                        <i class="bi bi-search"></i> Search
                    </button>
                    @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
                    }
                </div>
            </div>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No suppliers found. <a asp-action="Create">Create a new supplier</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Contact Person</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Products</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var supplier in Model)
                    {
                        <tr>
                            <td>@supplier.Name</td>
                            <td>@supplier.ContactPerson</td>
                            <td><a href="mailto:@supplier.Email">@supplier.Email</a></td>
                            <td>@supplier.Phone</td>
                            <td>
                                <span class="badge bg-info">@supplier.ProductCount</span>
                            </td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@supplier.SupplierId"
                                       class="btn btn-sm btn-info" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@supplier.SupplierId"
                                       class="btn btn-sm btn-warning" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@supplier.SupplierId"
                                       class="btn btn-sm btn-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">Total Suppliers: @Model.Count()</p>
        </div>
    }
</div>