    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Database Test";
}

<h2>Database Connection Test</h2>

<h3>Suppliers (@ViewBag.Suppliers.Count)</h3>
<ul>
    @foreach (var supplier in ViewBag.Suppliers)
    {
        <li>@supplier.Name - @supplier.Email</li>
    }
</ul>

<h3>Products (@ViewBag.Products.Count)</h3>
<ul>
    @foreach (var product in ViewBag.Products)
    {
        <li>@product.Name (SKU: @product.SKU) - Stock: @product.CurrentStock - Supplier: @(product.Supplier?.Name ?? "None")</li>
    }
</ul>
