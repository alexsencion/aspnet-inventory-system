@model IEnumerable<InventoryManagementSystem.Web.Models.ProductViewModel>

@{
    ViewData["Title"] = "Products";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Products</h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Product
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Index" method="get" class="mb-3">
        <div class="row g-3">
            <div class="col-md-4">
                <input type="text" name="searchTerm" class="form-control"
                       placeholder="Search by name, SKU, or description..."
                       value="@ViewBag.SearchTerm">
            </div>
            <div class="col-md-3">
                <select name="category" class="form-select" asp-items="@ViewBag.Categories">
                </select>
            </div>
            <div class="col-md-3">
                <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" name="lowStockOnly"
                           value="true" id="lowStockOnly"
                           @(ViewBag.LowStockOnly == true ? "checked" : "")>
                    <label class="form-check-label" for="lowStockOnly">
                        Low Stock Only
                    </label>
                </div>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-secondary w-100" type="submit">
                    <i class="bi bi-search"></i> Search
                </button>
                @if (!string.IsNullOrWhiteSpace(ViewBag.SearchTerm) ||
                                !string.IsNullOrWhiteSpace(ViewBag.Category) ||
                                ViewBag.LowStockOnly == true)
                {
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Clear</a>
                }
            </div>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No products found. <a asp-action="Create">Create a new product</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>SKU</th>
                        <th>Category</th>
                        <th>Supplier</th>
                        <th>Unit Price</th>
                        <th>Stock</th>
                        <th>Value</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr class="@(product.IsLowStock ? "table-warning" : "")">
                            <td>
                                @product.Name
                                @if (product.IsLowStock)
                                {
                                    <i class="bi bi-exclamation-triangle text-warning"
                                       title="Low Stock"></i>
                                }
                            </td>
                            <td><code>@product.SKU</code></td>
                            <td>@product.Category</td>
                            <td>@(product.SupplierName ?? "-")</td>
                            <td>@product.UnitPrice.ToString("C")</td>
                            <td>
                                <span class="badge @(product.IsLowStock ? "bg-warning text-dark" : "bg-success")">
                                    @product.CurrentStock
                                </span>
                                <small class="text-muted">/ @product.LowStockThreshold</small>
                            </td>
                            <td>@product.InventoryValue.ToString("C")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@product.ProductId"
                                       class="btn btn-sm btn-info" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@product.ProductId"
                                       class="btn btn-sm btn-warning" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@product.ProductId"
                                       class="btn btn-sm btn-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                Total Products: @Model.Count() |
                Low Stock Items: @Model.Count(p => p.IsLowStock) |
                Total Inventory Value: @Model.Sum(p => p.InventoryValue).ToString("C")
            </p>
        </div>
    }
</div>