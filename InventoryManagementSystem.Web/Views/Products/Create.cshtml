@model InventoryManagementSystem.Web.Models.ProductViewModel

@{
	ViewData["Title"] = "Create Product";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-8 offset-md-2">
			<h2>Create New Product</h2>
			<hr />

			<form asp-action="Create" method="post">
				<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

				<div class="row">
					<div class="col-md-8 mb-3">
						<label asp-for="Name" class="form-label"></label>
						<input asp-for="Name" class="form-control" />
						<span asp-validation-for="Name" class="text-danger"></span>
					</div>

					<div class="col-md-4 mb-3">
						<label asp-for="SKU" class="form-label"></label>
						<input asp-for="SKU" class="form-control" />
						<span asp-validation-for="SKU" class="text-danger"></span>
						<small class="text-muted">Unique identifier</small>
					</div>
				</div>

				<div class="col-md-6 mb-3">
					<label asp-for="Description" class="form-label"></label>
					<input asp-for="Description" class="form-control" />
					<span asp-validation-for="Description" class="text-danger"></span>
				</div>

				
				<div class="row">
					<div class="col-md-6 mb-3">
						<label asp-for="Category" class="form-label"></label>
						<input asp-for="Category" class="form-control" list="categoryList" />
						<datalist id="categoryList">
							@if (Model.Categories != null)
							{
								@foreach (var category in Model.Categories.Where(c => !string.IsNullOrEmpty(c.Value)))
								{
									<option value="@category.Text"></option>
								}
							}
						</datalist>
						<span asp-validation-for="Category" class="text-danger"></span>
					</div>

					<div class="col-md-6 mb-3">
						<label asp-for="SupplierId" class="form-label"></label>
						<select asp-for="SupplierId" class="form-select" asp-items="@Model.Suppliers">
						</select>
						<span asp-validation-for="SupplierId" class="text-danger"></span>
					</div>
				</div>

				<div class="row">
					<div class="col-md-6 mb-3">
						<label asp-for="UnitPrice" class="form-label"></label>
						<div class="input-group">
							<span class="input-group-text">$</span>
							<input asp-for="UnitPrice" class="form-control" type="number" step="0.01" />
						</div>
						<span asp-validation-for="UnitPrice" class="text-danger"></span>
					</div>

					<div class="col-md-6 mb-3">
						<label asp-for="LowStockThreshold" class="form-label"></label>
						<input asp-for="LowStockThreshold" class="form-control" type="number" />
						<span asp-validation-for="LowStockThreshold" class="text-danger"></span>
						<small class="text-muted">Alert when stock is at or below this value</small>
					</div>
				</div>

				<div class="alert alert-info">
					<i class="bi bg-info-circle"></i>
					New products start with 0 stock. Use stock Movements to add inventory
				</div>

				<div class="d-flex justify-content-between">
					<a asp-action="Index" class="btn btn-secondary">Cancel</a>
					<button type="submit" class="btn btn-primary">Create Product</button>
				</div>
			</form>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}