@model IEnumerable<InventoryManagementSystem.Web.Models.StockMovementViewModel>

@{
    ViewData["Title"] = "Stock Movements";
    var filter = ViewBag.Filter as InventoryManagementSystem.Web.Models.StockMovementFilterViewModel;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Stock Movements</h2>
        <div>
            <a asp-action="CreateIn" class="btn btn-success">
                <i class="bi bi-arrow-down-circle"></i> Stock IN
            </a>
            <a asp-action="CreateOut" class="btn btn-danger">
                <i class="bi bi-arrow-up-circle"></i> Stock OUT
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter Section -->
    <div class="card mb-3">
        <div class="card-header">
            <h5 class="mb-0">
                <i class="bi bi-funnel"></i> Filter Movements
            </h5>
        </div>
        <div class="card-body">
            <form asp-action="Index" method="get">
                <div class="row g-3">
                    <div class="col-md-3">
                        <label for="productId" class="form-label">Product</label>
                        <select name="productId" id="productId" class="form-select">
                            <option value="">-- All Products --</option>
                            @if (filter?.Products != null)
                            {
                                @foreach (var product in filter.Products.Where(p => !string.IsNullOrEmpty(p.Value)))
                                {
                                    <option value="@product.Value" selected="@(product.Value == filter.ProductId?.ToString())">
                                        @product.Text
                                    </option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="movementType" class="form-label">Movement Type</label>
                        <select name="movementType" id="movementType" class="form-select">
                            <option value="">-- All Types --</option>
                            <option value="IN" selected="@(filter?.MovementType?.ToString() == "IN")">Stock IN</option>
                            <option value="OUT" selected="@(filter?.MovementType?.ToString() == "OUT")">Stock OUT</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label for="startDate" class="form-label">Start Date</label>
                        <input type="date" name="startDate" id="startDate" class="form-control"
                               value="@(filter?.StartDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="col-md-2">
                        <label for="endDate" class="form-label">End Date</label>
                        <input type="date" name="endDate" id="endDate" class="form-control"
                               value="@(filter?.EndDate?.ToString("yyyy-MM-dd"))" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">&nbsp;</label>
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-search"></i> Apply Filter
                            </button>
                            @if (ViewBag.HasFilters)
                            {
                                <a asp-action="Index" class="btn btn-outline-secondary">
                                    Clear Filters
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            @if (ViewBag.HasFilters)
            {
                <text>No stock movements found matching your filters.</text>
            }
            else
            {
                <text>No stock movements recorded yet. <a asp-action="CreateIn">Record your first movement</a></text>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Product</th>
                        <th>SKU</th>
                        <th>Quantity</th>
                        <th>Reference/Reason</th>
                        <th>Stock After</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var movement in Model)
                    {
                        <tr>
                            <td>@movement.MovementDate.ToString("g")</td>
                            <td>
                                @if (movement.MovementType == InventoryManagementSystem.Data.Entities.MovementType.IN)
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-arrow-down-circle"></i> IN
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        <i class="bi bi-arrow-up-circle"></i> OUT
                                    </span>
                                }
                            </td>
                            <td>@movement.ProductName</td>
                            <td><code>@movement.ProductSKU</code></td>
                            <td>
                                <strong>
                                    @if (movement.MovementType == InventoryManagementSystem.Data.Entities.MovementType.IN)
                                    {
                                        <span class="text-success">+@movement.Quantity</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">-@movement.Quantity</span>
                                    }
                                </strong>
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(movement.Reference))
                                {
                                    <small class="text-muted">Ref: @movement.Reference</small>
                                }
                                @if (!string.IsNullOrWhiteSpace(movement.Reason))
                                {
                                    <small class="text-muted">@movement.Reason</small>
                                }
                            </td>
                            <td>
                                <span class="badge bg-info">@movement.StockAfterMovement</span>
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@movement.MovementId"
                                   class="btn btn-sm btn-info" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="mt-3">
            <p class="text-muted">
                Total Movements: @Model.Count() |
                Stock IN: @Model.Count(m => m.MovementType == InventoryManagementSystem.Data.Entities.MovementType.IN) |
                Stock OUT: @Model.Count(m => m.MovementType == InventoryManagementSystem.Data.Entities.MovementType.OUT)
            </p>
        </div>
    }
</div>